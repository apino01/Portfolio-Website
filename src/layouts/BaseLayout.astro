---
import "~/styles/global.css";
import SEOHead from "~/components/seo/SEOHead.astro";
import BackgroundScene from "~/components/scene/BackgroundScene.astro";
import BathymetryFooter from "~/components/footer/BathymetryFooter.astro";
import PingCursor from "~/components/effects/PingCursor.astro";

interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <SEOHead title={title} description={description} canonical={canonical} />
    {/* Cloudflare Web Analytics — replace ADD_YOUR_TOKEN_HERE with the
        token from dash.cloudflare.com → Web Analytics → Add a site. */}
    <script
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "ADD_YOUR_TOKEN_HERE"}'
    ></script>
  </head>
  <body class="min-h-dvh">
    <BackgroundScene />
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded focus:bg-teal focus:px-3 focus:py-2 focus:text-navy-black focus:font-medium"
    >
      Skip to content
    </a>
    <main id="main">
      <slot />
    </main>
    <BathymetryFooter />
    <PingCursor />
  </body>
</html>
