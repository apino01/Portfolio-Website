---
import "~/styles/global.css";
import SEOHead from "~/components/seo/SEOHead.astro";

interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <SEOHead title={title} description={description} canonical={canonical} />
  </head>
  <body class="min-h-dvh">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded focus:bg-teal focus:px-3 focus:py-2 focus:text-navy-black focus:font-medium"
    >
      Skip to content
    </a>
    <main id="main">
      <slot />
    </main>
  </body>
</html>
