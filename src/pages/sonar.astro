---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import ProjectCard from "~/components/projects/ProjectCard.astro";

const all = await getCollection("projects");
const sonar = all
  .filter((p) =>
    p.data.tags.some((t) =>
      /sonar|acoust|hydroph|towed|helras|mk54|lwwaa/i.test(t)
    ) || /sonar|acoust|sensor/i.test(p.data.domain)
  )
  .sort((a, b) => a.data.order - b.data.order);
const cards = sonar.map((p) => ({ ...p.data, body: p.body?.trim() ?? "" }));

const competencies = [
  "Active sonar arrays",
  "Towed-array sensors",
  "Dipping sonar (HELRAS)",
  "Sub-launched torpedo seekers",
  "Hydrophone signal chains",
  "Transducer R&D (textured ceramics)",
];
---

<BaseLayout
  title="Sonar & Acoustics — Andrés Pino"
  description="20 years building Navy sonar and acoustic sensor systems — MK54 torpedo seekers, LWWAA, HELRAS dipping sonar, TB-29 / TB-34A towed arrays. Available for advisory, design review, and technical due diligence engagements."
>
  <div class="mx-auto max-w-(--container-content) px-6 py-16 lg:px-12 lg:py-24">
    <a
      href="/"
      class="group inline-flex items-center gap-2 font-mono text-sm text-teal hover:underline"
    >
      <span aria-hidden="true" class="transition-transform group-hover:-translate-x-0.5">←</span>
      Back to home
    </a>

    <header class="mt-8 max-w-3xl">
      <p class="font-mono text-xs uppercase tracking-[0.20em] text-teal">
        Domain · Sonar & Acoustics
      </p>
      <h1 class="mt-3 text-3xl font-semibold text-near-white sm:text-4xl">
        Sonar systems, end-to-end — from transducer to track.
      </h1>
      <p class="mt-5 text-lg text-light-slate">
        I served as Chief Engineer at L3Harris's sonar facility in Salt Lake City,
        directing the MK54 lightweight torpedo seeker, LWWAA, HELRAS dipping sonar,
        and TB-29 / TB-34A submarine towed-array programs — over $150M in contracts
        and a $50M-revenue facility. Earlier I designed sonar suites for the
        Marlin AUV and the RAP-VLA passive surveillance system at Lockheed
        Martin Palm Beach.
      </p>
    </header>

    <div class="my-10 h-px w-full bg-slate/20" aria-hidden="true"></div>

    <section class="grid gap-12 lg:grid-cols-[2fr_1fr]">
      <div>
        <h2 class="text-xl font-semibold text-near-white">Programs delivered</h2>
        <div class="mt-4 -mx-4 grid gap-2 sm:-mx-6">
          {
            cards.map((c, i) => (
              <ProjectCard
                title={c.title}
                organization={c.organization}
                role={c.role}
                year={c.year}
                externalUrl={c.externalUrl}
                body={c.body}
                tags={c.tags}
                contactId={i + 1}
              />
            ))
          }
        </div>
      </div>

      <aside class="space-y-8">
        <div>
          <h2 class="font-mono text-xs uppercase tracking-[0.20em] text-teal">
            Capabilities in this domain
          </h2>
          <ul class="mt-3 space-y-2 text-sm text-light-slate">
            {
              competencies.map((c) => (
                <li class="flex items-start gap-2">
                  <span aria-hidden="true" class="mt-2 inline-block h-px w-3 flex-none bg-teal/60" />
                  <span>{c}</span>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="rounded-md border border-teal/30 bg-deep-navy/40 p-5">
          <p class="font-mono text-[10px] uppercase tracking-[0.20em] text-teal">
            Engage
          </p>
          <p class="mt-2 text-sm text-light-slate">
            Sonar architecture review, transducer-to-tracker trade-space analysis,
            or due-diligence on an acoustic-sensing claim.
          </p>
          <a
            href="/#contact"
            class="mt-4 inline-flex items-center gap-2 font-mono text-sm text-teal hover:underline"
          >
            Start a conversation
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </aside>
    </section>
  </div>
</BaseLayout>
