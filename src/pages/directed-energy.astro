---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import ProjectCard from "~/components/projects/ProjectCard.astro";

const all = await getCollection("projects");
const de = all
  .filter((p) =>
    p.data.tags.some((t) =>
      /hel|laser|directed|electro-?optical|llld|lld/i.test(t)
    ) || /directed|electro-?optical|laser/i.test(p.data.domain)
  )
  .sort((a, b) => a.data.order - b.data.order);
const cards = de.map((p) => ({ ...p.data, body: p.body?.trim() ?? "" }));

const competencies = [
  "High-energy laser power electronics",
  "Airborne HEL pod integration",
  "Weapon System Control Segment design",
  "Beam-control subsystem trades",
  "Electro-optical system architecture",
  "Reaper-class HEL flight demonstration",
];
---

<BaseLayout
  title="Directed Energy — Andrés Pino"
  description="High-energy laser and electro-optical systems engineering — Reaper-mounted HEL, Layered Laser Defense prototype, GA-EMS power electronics for HEL programs $50M to $350M+."
>
  <div class="mx-auto max-w-(--container-content) px-6 py-16 lg:px-12 lg:py-24">
    <a
      href="/"
      class="group inline-flex items-center gap-2 font-mono text-sm text-teal hover:underline"
    >
      <span aria-hidden="true" class="transition-transform group-hover:-translate-x-0.5">←</span>
      Back to home
    </a>

    <header class="mt-8 max-w-3xl">
      <p class="font-mono text-xs uppercase tracking-[0.20em] text-teal">
        Domain · Directed Energy
      </p>
      <h1 class="mt-3 text-3xl font-semibold text-near-white sm:text-4xl">
        High-energy lasers, from prototype to flight demonstration.
      </h1>
      <p class="mt-5 text-lg text-light-slate">
        Today I lead the power electronics group at General Atomics
        Electromagnetic Systems supporting HEL and electro-optical programs
        from $50M to $350M+, including a Reaper-mounted high-energy laser
        weapon system through critical design milestones. Earlier I served
        as Senior Lead Hardware Engineer on Lockheed Martin's Layered Laser
        Defense R&D prototype, owning the Weapon System Control Segment.
      </p>
    </header>

    <div class="my-10 h-px w-full bg-slate/20" aria-hidden="true"></div>

    <section class="grid gap-12 lg:grid-cols-[2fr_1fr]">
      <div>
        <h2 class="text-xl font-semibold text-near-white">Programs delivered</h2>
        <div class="mt-4 -mx-4 grid gap-2 sm:-mx-6">
          {
            cards.map((c, i) => (
              <ProjectCard
                title={c.title}
                organization={c.organization}
                role={c.role}
                year={c.year}
                externalUrl={c.externalUrl}
                body={c.body}
                tags={c.tags}
                contactId={i + 1}
              />
            ))
          }
        </div>
      </div>

      <aside class="space-y-8">
        <div>
          <h2 class="font-mono text-xs uppercase tracking-[0.20em] text-teal">
            Capabilities in this domain
          </h2>
          <ul class="mt-3 space-y-2 text-sm text-light-slate">
            {
              competencies.map((c) => (
                <li class="flex items-start gap-2">
                  <span aria-hidden="true" class="mt-2 inline-block h-px w-3 flex-none bg-teal/60" />
                  <span>{c}</span>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="rounded-md border border-teal/30 bg-deep-navy/40 p-5">
          <p class="font-mono text-[10px] uppercase tracking-[0.20em] text-teal">
            Engage
          </p>
          <p class="mt-2 text-sm text-light-slate">
            HEL architecture review, power-electronics trade-space analysis,
            or independent assessment of a directed-energy program claim.
          </p>
          <a
            href="/#contact"
            class="mt-4 inline-flex items-center gap-2 font-mono text-sm text-teal hover:underline"
          >
            Start a conversation
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </aside>
    </section>
  </div>
</BaseLayout>
