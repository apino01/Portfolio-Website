---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import ProjectCard from "~/components/projects/ProjectCard.astro";

const all = await getCollection("projects");
const sorted = all.sort((a, b) => a.data.order - b.data.order);
const cards = sorted.map((p) => ({ ...p.data, body: p.body?.trim() ?? "" }));

// Group by domain for an at-a-glance index above the grid.
const domains = Array.from(new Set(cards.map((c) => c.domain)));
---

<BaseLayout
  title="Projects — Andrés Pino"
  description="Selected engineering work across power electronics, undersea systems and autonomy, naval platform and seabed sensors, and directed energy. Programs at Lockheed Martin, General Atomics, L3Harris, and Terradepth."
>
  <div
    class="px-6 py-16 lg:px-16 lg:py-24 xl:px-24 2xl:px-32"
  >
    <header class="mb-10 max-w-prose">
      <a
        href="/"
        class="group inline-flex items-center gap-2 font-mono text-sm text-teal hover:underline"
      >
        <span aria-hidden="true" class="transition-transform group-hover:-translate-x-0.5">←</span>
        Back to home
      </a>

      <h1 class="mt-6 text-3xl font-semibold text-near-white sm:text-4xl">
        All Projects
      </h1>
      <p class="mt-4 text-slate">
        Programs and product work spanning {cards.length} engagements across
        defense, maritime, and undersea-autonomy domains. Each links out to the
        employer's published page or product reference.
      </p>

      <ul
        class="mt-6 flex flex-wrap gap-2"
        aria-label="Domains"
      >
        {
          domains.map((d) => (
            <li>
              <span class="inline-flex items-center rounded-full bg-teal-dim px-3 py-1 font-mono text-xs text-teal">
                {d}
              </span>
            </li>
          ))
        }
      </ul>
    </header>

    <div class="-mx-4 grid gap-2 sm:-mx-6 md:grid-cols-2">
      {
        cards.map((c, i) => (
          <ProjectCard
            title={c.title}
            organization={c.organization}
            role={c.role}
            year={c.year}
            externalUrl={c.externalUrl}
            body={c.body}
            tags={c.tags}
            contactId={i + 1}
          />
        ))
      }
    </div>
  </div>
</BaseLayout>
