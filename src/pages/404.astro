---
import BaseLayout from "~/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Page not found"
  description="The page you're looking for doesn't exist."
>
  <div
    class="mx-auto flex min-h-dvh max-w-(--container-content) flex-col items-start justify-center px-6 lg:px-12"
  >
    <p class="section-marker mb-3">404</p>
    <h1 class="text-4xl text-near-white sm:text-5xl">Page not found</h1>
    <p class="mt-4 text-slate">
      The page you're looking for doesn't exist or has moved.
    </p>
    <a
      href="/"
      class="mt-8 inline-block font-mono text-sm text-teal hover:underline"
      >&larr; back home</a
    >
  </div>
</BaseLayout>
