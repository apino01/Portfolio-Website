---
import { Image } from "astro:assets";
import headshot from "~/assets/headshot.jpg";
import AvailabilityBadge from "./AvailabilityBadge.astro";
import SideNav from "~/components/nav/SideNav.astro";
import IconLink from "~/components/ui/IconLink.astro";
import LinkedInIcon from "~/components/ui/icons/LinkedInIcon.astro";
import DocumentIcon from "~/components/ui/icons/DocumentIcon.astro";

const navItems = [
  { id: "about", label: "About" },
  { id: "experience", label: "Experience" },
  { id: "projects", label: "Projects" },
  { id: "contact", label: "Contact" },
];
---

<header
  class="flex flex-col gap-10 lg:sticky lg:top-0 lg:flex h-auto lg:h-dvh lg:max-h-dvh lg:py-24"
>
  <div class="flex flex-col gap-6">
    <AvailabilityBadge />

    <div class="flex items-center gap-5">
      <Image
        src={headshot}
        alt="Portrait of Andrés Pino"
        width={160}
        height={160}
        densities={[1, 2]}
        formats={["avif", "webp"]}
        loading="eager"
        class="h-20 w-20 rounded-full border border-teal/25 object-cover shadow-[0_0_0_5px_rgb(6_26_44/_0.7)]"
      />
      <div>
        <h1 class="text-3xl font-semibold tracking-tight text-near-white sm:text-4xl">
          Andrés Pino
        </h1>
        <p class="mt-1 text-base text-light-slate">
          Senior Electrical &amp; Systems Engineering Leader
        </p>
      </div>
    </div>

    <p class="max-w-md leading-relaxed text-slate">
      I'm a senior electrical and systems engineering leader with 20 years of
      experience helping teams develop complex maritime and defense hardware
      from concept through architecture, integration, test, manufacturing, and
      delivery.
    </p>

    {/* Single-line trust anchor — buyer-facing authority signal */}
    <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-slate/85">
      <span class="text-teal/85">Programs delivered for:</span>
      General Atomics · L3Harris · Lockheed Martin · Terradepth · U.S. Navy
    </p>

    <p class="font-mono text-xs uppercase tracking-widest text-slate/80">
      Active TS Clearance · San Diego, CA
    </p>

    {/* Primary CTA — convert visitors who arrived through a referral */}
    <a
      href="#contact"
      class="hero-cta group inline-flex w-fit items-center gap-2 rounded-md border border-teal/40 bg-teal/10 px-4 py-2 font-mono text-sm text-teal transition-colors hover:bg-teal/20 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal"
    >
      Send a note
      <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">↓</span>
    </a>
  </div>

  <SideNav items={navItems} />

  {/* Mobile-only inline section jumplist */}
  <nav aria-label="Page sections" class="lg:hidden">
    <ul class="flex flex-wrap gap-2">
      {
        navItems.map((item) => (
          <li>
            <a
              href={`#${item.id}`}
              class="inline-flex items-center rounded-full border border-slate/20 px-3 py-1 font-mono text-xs uppercase tracking-widest text-slate hover:border-teal/40 hover:text-teal"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <ul class="mt-auto flex flex-wrap items-center gap-x-5 gap-y-2" aria-label="Social and resume">
    <li>
      <a
        href="/andres-pino-resume.pdf"
        class="group inline-flex items-center gap-1.5 font-mono text-xs uppercase tracking-[0.18em] text-light-slate hover:text-teal"
      >
        <DocumentIcon />
        <span>Résumé (PDF)</span>
        <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">↗</span>
      </a>
    </li>
    <li>
      <IconLink
        href="https://www.linkedin.com/in/andresmpino/"
        label="LinkedIn profile"
      >
        <LinkedInIcon />
      </IconLink>
    </li>
  </ul>
</header>
