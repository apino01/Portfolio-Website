      opacity="0.20"
    >
      <path d="M 276 96 L 1200 96" />
    </g>
    <g fill="var(--color-teal, #38e8c6)" opacity="0.24">
      <rect x="780" y="80" width="26" height="18" rx="2" />
      <circle cx="793" cy="74" r="3.5" />
      <rect x="788" y="69" width="10" height="6" />
      <rect x="850" y="86" width="14" height="12" rx="2" />
    </g>
    <g fill="var(--color-teal, #38e8c6)" opacity="0.20">
      <path d="M 1020 92 Q 1022 84 1032 83 L 1100 83 Q 1112 83 1118 92 Q 1112 98 1100 98 L 1032 98 Q 1022 97 1020 92 Z" />
