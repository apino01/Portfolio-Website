      {/* Wing-edge flange (thin horizontal line — manta wings seen edge-on) */}
      <rect x="40" y="29" width="320" height="1.5" opacity="0.45" />
      {/* Sensor mast (top) */}
      <rect x="212" y="0" width="2" height="4" />
      {/* Tail control surface at stern (right) */}
      <path d="M 28 30 L 8 18 L 8 42 Z" />
      {/* Nose sensor at left */}
      <circle cx="384" cy="30" r="2" opacity="0.95" />
      {/* Thruster at stern */}
      <g class="bg-propeller-spin">
        <circle cx="15" cy="30" r="3" opacity="0.5" />
        <line x1="15" y1="24" x2="15" y2="36" stroke="#38e8c6" stroke-width="0.8" opacity="0.6" />
      </g>
    </g>
  </svg>

  {/* Bottom-scanning UUV — wide swath (300% larger cone), propeller at stern, forward sonar at bow */}
  <svg
    class="bg-vessel bg-vessel-sonar-uuv absolute"
    style="bottom: 4%; left: -10%; width: 1200px; height: 180px;"
    viewBox="0 0 1200 210"
    preserveAspectRatio="xMidYMid meet"
  >
    {/* UUV body — centered in wider canvas, bow RIGHT (matches drift-right), stern LEFT */}
    <g fill="var(--color-teal, #38e8c6)" opacity="0.26">
      <path d="M 420 42 Q 424 20 452 18 L 724 18 Q 748 18 760 42 Q 748 66 724 68 L 452 68 Q 424 66 420 42 Z" />
      {/* Sail */}
      <path d="M 550 18 L 564 6 L 644 6 L 658 18 Z" />
      {/* Stern control fin (left) */}
      <path d="M 422 42 L 402 24 L 402 60 Z" />
      {/* Nose sensor at bow (right) */}
      <circle cx="754" cy="42" r="3.2" opacity="0.95" />
    </g>

    {/* Propeller at stern (left) */}
    <circle cx="396" cy="42" r="6" fill="var(--color-teal, #38e8c6)" opacity="0.26" />
    <g class="bg-propeller-spin">
      <ellipse cx="396" cy="42" rx="2.5" ry="18" fill="var(--color-teal, #38e8c6)" opacity="0.5" />
      <line x1="396" y1="24" x2="396" y2="60" stroke="#38e8c6" stroke-width="1" opacity="0.6" />
    </g>

    {/* Forward-looking sonar — projects right from bow */}
    <g class="bg-torp-sonar">
      <path d="M 760 36 L 856 6 L 856 78 L 760 48 Z" fill="var(--color-teal, #38e8c6)" opacity="0.10" />
    </g>
    <g fill="none" stroke="var(--color-teal, #38e8c6)" stroke-width="1.2">
      <path class="bg-torp-arc bg-torp-arc-1" d="M 778 37 Q 783 42 778 47" opacity="0" />
      <path class="bg-torp-arc bg-torp-arc-2" d="M 802 28 Q 810 42 802 56" opacity="0" />
      <path class="bg-torp-arc bg-torp-arc-3" d="M 830 16 Q 842 42 830 68" opacity="0" />
    </g>

    {/* Downward sonar beam — 300% larger cone, spans full 1200px width */}
    <g class="bg-sonar-beam">
      <path d="M 560 68 L 0 198 L 1200 198 L 640 68 Z" fill="var(--color-teal, #38e8c6)" opacity="0.10" />
    </g>

    {/* Sonar return arcs — span full swath */}
    <g fill="none" stroke="var(--color-teal, #38e8c6)" stroke-width="1.2">
