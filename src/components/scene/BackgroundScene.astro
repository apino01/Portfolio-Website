---
// Subsea depth scene v5 — US Navy fleet, populated.
//
// Depth bands:
//   surface          → destroyer + MH-60R helicopter (HELRAS dipping cycle)
//   upper photic     → Ohio-class SSGN + lightweight torpedo (Mk54)
//   mid-water        → Virginia-class SSN + heavyweight torpedo (Mk48) + LA-class SSN
//   deeper mid       → Marlin AUV (Lockheed)
//   mesopelagic      → XLUUV (Boeing Orca) + MDUUV (Snakehead-class) + Manta Ray glider
//   abyssal seabed   → pipeline + wellhead + sensor pod + docked AUV
//                      + bottom-scanning UUV pinging the silt
//
// Helicopter sequence (90s loop, 11 phases):
//   0–7%   fly in from right
//   7–12%  hover (sonar tucked)
//   12–25% lower sonar package on cable
//   25–32% 8 arms deploy radially in lower hemisphere
//   32–42% 3 hydrophone plates drop
//   42–52% plates retract
//   52–62% arms close
//   62–75% raise sonar back to helicopter
//   75–82% hover (sonar tucked)
//   82–100% fly off to the left
---

<div
  class="background-scene pointer-events-none absolute inset-0 overflow-hidden"
  aria-hidden="true"
>
  {/* Subtle depth gradient */}
  <div class="bg-depth-gradient absolute inset-0"></div>

  {/* Caustic light rays — top ~22%, very faint */}
  <svg
    class="bg-caustics absolute inset-x-0 top-0 h-[24vh] w-full opacity-[0.05]"
    viewBox="0 0 1200 400"
    preserveAspectRatio="none"
  >
    <defs>
      <linearGradient id="caustic-fade" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#7fdbff" stop-opacity="0.85" />
        <stop offset="100%" stop-color="#7fdbff" stop-opacity="0" />
      </linearGradient>
    </defs>
    <g stroke="url(#caustic-fade)" stroke-width="1.4" fill="none">
      <path d="M 80 0 Q 120 80 60 200 T 100 400" />
      <path d="M 240 0 Q 200 100 280 220 T 240 400" />
      <path d="M 420 0 Q 460 90 380 210 T 440 400" />
      <path d="M 600 0 Q 560 110 640 230 T 600 400" />
      <path d="M 780 0 Q 820 80 740 200 T 800 400" />
      <path d="M 960 0 Q 920 100 1000 220 T 960 400" />
      <path d="M 1120 0 Q 1080 90 1160 210 T 1120 400" />
    </g>
  </svg>

  {/* ════════ SURFACE BAND ════════ */}

  {/* Destroyer */}
  <svg
    class="bg-vessel bg-vessel-ship absolute"
    style="top: 6%; left: -12%; width: 520px; height: 90px;"
    viewBox="0 0 600 100"
    preserveAspectRatio="xMidYMid meet"
  >
    <g fill="var(--color-teal, #38e8c6)" opacity="0.20">
      <path d="M 18 56 Q 32 76 80 82 L 480 82 Q 540 82 580 62 L 580 56 Z" />
      <rect x="190" y="36" width="100" height="22" rx="2" />
      <rect x="320" y="38" width="70" height="18" rx="2" />
      <rect x="232" y="10" width="3" height="28" />
      <ellipse cx="234" cy="16" rx="14" ry="3" />
      <rect x="350" y="20" width="2" height="20" />
      <rect x="140" y="48" width="20" height="10" rx="2" />
    </g>
    <g fill="var(--color-teal, #38e8c6)" opacity="0.10">
      <ellipse cx="588" cy="68" rx="10" ry="3" />
      <ellipse cx="600" cy="62" rx="6" ry="2" />
      <ellipse cx="608" cy="68" rx="5" ry="1.5" />
    </g>
  </svg>

  {/* Helicopter with full HELRAS deployment choreography */}
  <svg
    class="bg-vessel bg-vessel-helo absolute"
    style="top: 2%; right: 8%; width: 200px; height: 480px;"
    viewBox="0 0 240 580"
    preserveAspectRatio="xMidYMid meet"
  >
    {/* Cable — drawn first (behind sonar body), animates scaleY 0 → 1 */}
    <rect
      class="bg-helo-cable"
      x="109"
      y="116"
      width="2"
      height="440"
      fill="var(--color-teal, #38e8c6)"
      opacity="0.30"
    />

    {/* Sonar rig group — translates Y to descend along the cable */}
    <g class="bg-helo-sonar-rig">
      {/* Arms — drawn first (under body so deployment looks like they emerge from beneath) */}
      <rect class="bg-helo-arm" style="--angle: 20deg"  x="110" y="147" width="25" height="2" rx="1" fill="var(--color-teal, #38e8c6)" />
      <rect class="bg-helo-arm" style="--angle: 40deg"  x="110" y="147" width="25" height="2" rx="1" fill="var(--color-teal, #38e8c6)" />
      <rect class="bg-helo-arm" style="--angle: 60deg"  x="110" y="147" width="25" height="2" rx="1" fill="var(--color-teal, #38e8c6)" />
      <rect class="bg-helo-arm" style="--angle: 80deg"  x="110" y="147" width="25" height="2" rx="1" fill="var(--color-teal, #38e8c6)" />
      <rect class="bg-helo-arm" style="--angle: 100deg" x="110" y="147" width="25" height="2" rx="1" fill="var(--color-teal, #38e8c6)" />
      <rect class="bg-helo-arm" style="--angle: 120deg" x="110" y="147" width="25" height="2" rx="1" fill="var(--color-teal, #38e8c6)" />
      <rect class="bg-helo-arm" style="--angle: 140deg" x="110" y="147" width="25" height="2" rx="1" fill="var(--color-teal, #38e8c6)" />
      <rect class="bg-helo-arm" style="--angle: 160deg" x="110" y="147" width="25" height="2" rx="1" fill="var(--color-teal, #38e8c6)" />

      {/* Sonar body cylinder */}
      <rect x="98" y="116" width="24" height="32" rx="3" fill="var(--color-teal, #38e8c6)" opacity="0.34" />
      <ellipse cx="110" cy="148" rx="14" ry="2.5" fill="var(--color-teal, #38e8c6)" opacity="0.50" />

      {/* 3 hydrophone plates that drop from inside the cylinder */}
      <rect class="bg-helo-plate" x="100" y="146" width="5" height="3" rx="1" fill="var(--color-teal, #38e8c6)" />
      <rect class="bg-helo-plate" x="107" y="146" width="6" height="3" rx="1" fill="var(--color-teal, #38e8c6)" />
      <rect class="bg-helo-plate" x="115" y="146" width="5" height="3" rx="1" fill="var(--color-teal, #38e8c6)" />
    </g>

    {/* Helicopter airframe — MH-60R Romeo silhouette */}
    <g class="bg-helo-airframe">
      <g fill="var(--color-teal, #38e8c6)" opacity="0.26">
        {/* 4-blade main rotor disc — wider than legacy 2-blade */}
        <ellipse cx="110" cy="38" rx="106" ry="3" opacity="0.45" />
        {/* Faint diagonal blade hints (4-blade rotor signature) */}
        <line x1="8" y1="38" x2="212" y2="38" stroke="#38e8c6" stroke-width="1" opacity="0.35" />
        <line x1="38" y1="22" x2="182" y2="54" stroke="#38e8c6" stroke-width="0.6" opacity="0.20" />
        <line x1="38" y1="54" x2="182" y2="22" stroke="#38e8c6" stroke-width="0.6" opacity="0.20" />

        {/* Rotor hub + mast */}
        <rect x="104" y="36" width="12" height="4" rx="1" />
        <rect x="108" y="40" width="4" height="12" />

        {/* Twin GE T700 engine intakes — characteristic bulges behind mast */}
        <path d="M 92 50 Q 92 46 96 46 L 110 46 Q 114 46 114 50 L 114 56 L 92 56 Z" />
        <path d="M 106 50 Q 106 46 110 46 L 124 46 Q 128 46 128 50 L 128 56 L 106 56 Z" />

        {/* Main fuselage / cabin — squared Sikorsky H-60 profile */}
        <path d="M 56 58 Q 50 64 50 80 L 50 98 Q 50 110 62 112 L 154 112 Q 168 110 172 100 L 172 78 Q 172 60 158 56 L 70 56 Q 60 56 56 58 Z" />

        {/* Chin-mounted APS-153 multi-mode radar dome — under the nose */}
        <ellipse cx="58" cy="110" rx="12" ry="6" />

        {/* FLIR turret — small ball ahead of the radome */}
        <circle cx="48" cy="100" r="3.5" opacity="0.85" />

        {/* Sonobuoy launcher tubes — port side fuselage (RSL grid) */}
        <rect x="84" y="100" width="18" height="8" rx="1" opacity="0.65" />

        {/* Tail boom — narrower than fuselage */}
        <rect x="172" y="80" width="56" height="9" rx="3" />

        {/* Stabilator — horizontal stab at tail base */}
        <rect x="200" y="84" width="32" height="2.5" rx="1" />

        {/* Vertical tail pylon — supports the canted tail rotor */}
        <path d="M 220 80 Q 226 64 232 60 L 240 68 L 234 88 Z" />

        {/* Wheel sponsons — Romeo has retractable gear in side sponsons */}
        <ellipse cx="80" cy="116" rx="11" ry="4" opacity="0.75" />
        <ellipse cx="148" cy="116" rx="11" ry="4" opacity="0.75" />
        {/* Tail wheel under tail boom */}
        <ellipse cx="216" cy="93" rx="3.5" ry="2.5" opacity="0.7" />
      </g>

      {/* Canted tail rotor (~18° Sikorsky H-60 signature cant) */}
      <g transform="rotate(-18 234 74)">
        <ellipse cx="234" cy="74" rx="2.5" ry="12" fill="var(--color-teal, #38e8c6)" opacity="0.50" />
        <line x1="234" y1="62" x2="234" y2="86" stroke="#38e8c6" stroke-width="0.8" opacity="0.55" />
      </g>

      {/* Cockpit windscreen — sloped front, dark tinted */}
      <path d="M 56 78 Q 60 66 80 62 L 100 62 L 100 78 Z" fill="#0a2540" opacity="0.45" />
      {/* Pilot/copilot window divider */}
      <line x1="78" y1="62" x2="80" y2="78" stroke="#0a2540" stroke-width="0.8" opacity="0.5" />

      {/* Cabin sliding door window — subtle outline */}
      <rect x="104" y="78" width="38" height="22" rx="1" fill="#0a2540" stroke="none" opacity="0.18" />
    </g>
  </svg>

  {/* ════════ UPPER PHOTIC BAND ════════ */}

  {/* OHIO class (SSGN/SSBN) — largest sub, missile deck. BOW RIGHT, STERN LEFT.
      Drifts RIGHT so the bow leads forward motion; bow sonar pings ahead. */}
  <svg
    class="bg-vessel bg-vessel-ohio absolute"
    style="top: 22%; left: -10%; width: 690px; height: 112px;"
    viewBox="0 0 800 130"
    preserveAspectRatio="xMidYMid meet"
  >
    <g fill="var(--color-teal, #38e8c6)" opacity="0.18">
      {/* Long teardrop hull (bow right, stern left) */}
      <path d="M 690 65 Q 670 28 590 24 L 120 24 Q 50 28 20 65 Q 50 102 120 106 L 590 106 Q 670 102 690 65 Z" />
      {/* Sail with sail-mounted dive planes */}
      <path d="M 520 24 Q 516 4 488 2 L 400 2 Q 372 4 366 24 Z" />
      <rect x="388" y="14" width="100" height="4" rx="1" />
      <rect x="450" y="-4" width="2" height="8" />
      <rect x="435" y="-3" width="2" height="7" />
      {/* Missile deck (24 SLBM tubes, simplified to 8 hatches) */}
      <rect x="110" y="20" width="240" height="4" opacity="0.30" />
      <ellipse cx="135" cy="22" rx="6" ry="3" opacity="0.55" />
      <ellipse cx="163" cy="22" rx="6" ry="3" opacity="0.55" />
      <ellipse cx="191" cy="22" rx="6" ry="3" opacity="0.55" />
      <ellipse cx="219" cy="22" rx="6" ry="3" opacity="0.55" />
      <ellipse cx="247" cy="22" rx="6" ry="3" opacity="0.55" />
      <ellipse cx="275" cy="22" rx="6" ry="3" opacity="0.55" />
      <ellipse cx="303" cy="22" rx="6" ry="3" opacity="0.55" />
      <ellipse cx="331" cy="22" rx="6" ry="3" opacity="0.55" />
      {/* Cruciform tail X-fins at stern (left side) */}
      <path d="M 20 65 L 2 36 L 8 60 Z" />
      <path d="M 20 65 L 2 94 L 8 70 Z" />
      <path d="M 20 65 L 8 50 L 8 58 Z" />
      <path d="M 20 65 L 8 80 L 8 72 Z" />
      {/* Pump-jet propulsor with spinning blades */}
      <circle cx="10" cy="65" r="4" />
      <g class="bg-propeller-spin">
        <ellipse cx="10" cy="65" rx="2" ry="10" opacity="0.5" />
        <line x1="10" y1="55" x2="10" y2="75" stroke="#38e8c6" stroke-width="0.8" opacity="0.6" />
      </g>
      {/* Bow sonar dome (forward of pressure hull) */}
      <ellipse cx="688" cy="65" rx="4" ry="9" opacity="0.55" />
    </g>
    {/* Active forward-looking sonar fan beam */}
    <g class="bg-sub-sonar">
      <path d="M 690 50 L 790 22 L 790 108 L 690 80 Z" fill="var(--color-teal, #38e8c6)" opacity="0.10" />
    </g>
    {/* Sonar return arcs traveling forward from bow */}
    <g fill="none" stroke="var(--color-teal, #38e8c6)" stroke-width="1.2">
      <path class="bg-sub-arc bg-sub-arc-1" d="M 708 53 Q 714 65 708 77" opacity="0" />
      <path class="bg-sub-arc bg-sub-arc-2" d="M 736 44 Q 746 65 736 86" opacity="0" />
      <path class="bg-sub-arc bg-sub-arc-3" d="M 766 33 Q 780 65 766 97" opacity="0" />
    </g>
  </svg>

  {/* Lightweight torpedo (Mk54-style) — nose forward (right), cavitation trail
      behind, active sonar fan beam projecting ahead */}
  <svg
    class="bg-vessel bg-vessel-torpedo-lw absolute"
    style="top: 32%; left: -12%; width: 340px; height: 45px;"
    viewBox="0 0 380 50"
    preserveAspectRatio="xMidYMid meet"
  >
    {/* Cavitation bubble trail (trailing behind tail) */}
    <g fill="var(--color-teal, #38e8c6)" opacity="0.18">
      <circle cx="6" cy="25" r="1.5" />
      <circle cx="16" cy="22" r="2" />
      <circle cx="28" cy="27" r="2.5" />
      <circle cx="42" cy="23" r="2.5" />
      <circle cx="56" cy="26" r="2" />
    </g>
    <g fill="var(--color-teal, #38e8c6)" opacity="0.28">
      {/* Tail X-fins at the back (left side) */}
      <path d="M 70 25 L 56 14 L 56 22 Z" />
      <path d="M 70 25 L 56 36 L 56 28 Z" />
      <rect x="68" y="11" width="20" height="3" />
      <rect x="68" y="36" width="20" height="3" />
      {/* Body — rounded tail (left) tapering to pointed nose (right) */}
      <path d="M 70 25 Q 72 17 88 17 L 240 17 Q 270 17 290 25 Q 270 33 240 33 L 88 33 Q 72 32 70 25 Z" />
      {/* Nose */}
      <circle cx="284" cy="25" r="1.4" opacity="0.9" />
    </g>
    {/* Active sonar fan beam projecting forward from nose */}
    <g class="bg-torp-sonar">
      <path d="M 290 19 L 376 4 L 376 46 L 290 31 Z" fill="var(--color-teal, #38e8c6)" opacity="0.10" />
    </g>
    {/* Sonar return arcs traveling forward from nose */}
    <g fill="none" stroke="var(--color-teal, #38e8c6)" stroke-width="1">
      <path class="bg-torp-arc bg-torp-arc-1" d="M 308 19 Q 312 25 308 31" opacity="0" />
      <path class="bg-torp-arc bg-torp-arc-2" d="M 332 14 Q 338 25 332 36" opacity="0" />
      <path class="bg-torp-arc bg-torp-arc-3" d="M 358 9  Q 366 25 358 41" opacity="0" />
    </g>
  </svg>

  {/* ════════ MID-WATER BAND ════════ */}

  {/* VIRGINIA class (SSN-774) — sleek teardrop sail, NO sail planes, pump-jet stern — oriented to drift RIGHT (bow right) */}
  <svg
    class="bg-vessel bg-vessel-virginia absolute"
    style="top: 40%; left: -10%; width: 540px; height: 99px;"
    viewBox="0 0 600 110"
    preserveAspectRatio="xMidYMid meet"
  >
    <g fill="var(--color-teal, #38e8c6)" opacity="0.18">
      {/* Hull — bow at right, stern at left */}
      <path d="M 572 55 Q 540 26 480 23 L 100 23 Q 36 26 24 55 Q 36 84 100 87 L 480 87 Q 540 84 572 55 Z" />
      {/* Teardrop sail — Virginia's signature sleek profile (no dive planes) */}
      <path d="M 350 23 Q 350 4 302 2 L 255 2 Q 230 4 228 23 Z" />
      {/* Photonics mast (Virginia uses non-penetrating optronics, not periscope) */}
      <rect x="292" y="-3" width="2" height="6" />
      <rect x="285" y="-2" width="2" height="5" />
      {/* Pump-jet propulsor — distinctive cylindrical shroud at stern (left side) */}
      <rect x="8" y="40" width="20" height="30" rx="3" opacity="0.45" />
      <line x1="18" y1="40" x2="18" y2="70" stroke="#38e8c6" stroke-width="0.8" opacity="0.6" />
      {/* Stern X-fins (cruciform, partially inside shroud) */}
      <path d="M 28 55 L 12 36 L 16 53 Z" />
      <path d="M 28 55 L 12 74 L 16 57 Z" />
      {/* Spinning pump-jet blades */}
      <g class="bg-propeller-spin">
        <ellipse cx="18" cy="55" rx="1.5" ry="12" opacity="0.5" />
      </g>
    </g>
  </svg>

  {/* Heavyweight torpedo (Mk48-style) — nose forward (right), cavitation trail
      behind, active sonar fan beam projecting ahead */}
  <svg
    class="bg-vessel bg-vessel-torpedo-hw absolute"
    style="top: 50%; left: -12%; width: 380px; height: 60px;"
    viewBox="0 0 440 60"
    preserveAspectRatio="xMidYMid meet"
  >
    {/* Cavitation bubble trail (trailing behind tail) */}
    <g fill="var(--color-teal, #38e8c6)" opacity="0.20">
      <circle cx="4" cy="30" r="1.5" />
      <circle cx="14" cy="27" r="2.2" />
      <circle cx="26" cy="32" r="3" />
      <circle cx="40" cy="28" r="3.5" />
      <circle cx="56" cy="30" r="3" />
      <circle cx="72" cy="32" r="2.5" />
      <circle cx="86" cy="28" r="2" />
    </g>
    <g fill="var(--color-teal, #38e8c6)" opacity="0.30">
      {/* Tail X-fins at the back (left side) — bigger control surfaces for HW */}
      <path d="M 100 30 L 86 12 L 86 22 Z" />
      <path d="M 100 30 L 86 48 L 86 38 Z" />
      <rect x="98" y="9" width="22" height="4" />
      <rect x="98" y="47" width="22" height="4" />
      {/* Propeller hub at extreme back */}
      <circle cx="92" cy="30" r="3" />
      {/* Body — rounded tail (left) tapering to pointed nose (right) */}
      <path d="M 100 30 Q 104 18 124 16 L 380 16 Q 410 16 420 30 Q 410 44 380 44 L 124 44 Q 104 42 100 30 Z" />
      {/* Warhead band near nose */}
      <rect x="380" y="29" width="36" height="2" opacity="0.4" />
      {/* Nose sensor */}
      <circle cx="416" cy="30" r="2" opacity="0.95" />
    </g>
    {/* Active sonar fan beam projecting forward from nose */}
    <g class="bg-torp-sonar">
      <path d="M 420 24 L 520 8 L 520 52 L 420 36 Z" fill="var(--color-teal, #38e8c6)" opacity="0.10" />
    </g>
    {/* Sonar return arcs traveling forward from nose */}
    <g fill="none" stroke="var(--color-teal, #38e8c6)" stroke-width="1">
      <path class="bg-torp-arc bg-torp-arc-1" d="M 438 24 Q 442 30 438 36" opacity="0" />
      <path class="bg-torp-arc bg-torp-arc-2" d="M 462 19 Q 468 30 462 41" opacity="0" />
      <path class="bg-torp-arc bg-torp-arc-3" d="M 488 14 Q 496 30 488 46" opacity="0" />
    </g>
  </svg>

  {/* LOS ANGELES class (SSN-688) — sail-mounted dive planes, conventional propeller — drifts LEFT, bow LEFT */}
  <svg
    class="bg-vessel bg-vessel-la absolute"
    style="top: 58%; right: -10%; width: 500px; height: 94px;"
    viewBox="0 0 560 105"
    preserveAspectRatio="xMidYMid meet"
  >
    {/* Flip content so bow (pointed end) is at SVG left and propeller trails at SVG right */}
    <g transform="translate(560 0) scale(-1 1)">
      <g fill="var(--color-teal, #38e8c6)" opacity="0.18">
        {/* Hull (cigar profile) */}
        <path d="M 536 53 Q 528 24 470 22 L 100 22 Q 40 24 18 53 Q 40 82 100 84 L 470 84 Q 528 82 536 53 Z" />
        {/* Sail */}
        <path d="M 360 22 Q 356 4 338 2 L 270 2 Q 252 4 248 22 Z" />
        {/* Sail-mounted dive planes */}
        <rect x="252" y="13" width="86" height="4" rx="1" />
        {/* Twin periscopes / masts */}
        <rect x="308" y="-3" width="2" height="7" />
        <rect x="294" y="-1" width="2" height="5" />
        {/* Cruciform stern surfaces — now trail on the right after flip */}
        <path d="M 18 53 L 2 30 L 8 50 Z" />
        <path d="M 18 53 L 2 76 L 8 56 Z" />
        <path d="M 18 53 L 8 40 L 8 50 Z" />
        <path d="M 18 53 L 8 66 L 8 56 Z" />
        {/* Conventional propeller with spinning blades */}
        <g class="bg-propeller-spin">
          <ellipse cx="10" cy="53" rx="2.5" ry="13" opacity="0.42" />
          <line x1="10" y1="40" x2="10" y2="66" stroke="#38e8c6" stroke-width="0.8" opacity="0.55" />
        </g>
        <circle cx="14" cy="53" r="3.5" opacity="0.7" />
      </g>
    </g>
  </svg>

  {/* AUV — Marlin (Lockheed Martin commercial AUV — Andres' work) */}
  <svg
    class="bg-vessel bg-vessel-marlin absolute"
    style="top: 68%; right: -10%; width: 380px; height: 60px;"
    viewBox="0 0 420 60"
    preserveAspectRatio="xMidYMid meet"
  >
    <g fill="var(--color-teal, #38e8c6)" opacity="0.22">
      <path d="M 14 30 Q 18 12 38 10 L 350 10 Q 380 10 400 30 Q 380 50 350 50 L 38 50 Q 18 48 14 30 Z" />
      <path d="M 140 10 L 152 0 L 220 0 L 232 10 Z" />
      <path d="M 400 30 L 418 14 L 418 46 Z" />
      <circle cx="20" cy="30" r="2.2" opacity="0.95" />
      <rect x="60" y="29" width="280" height="2" opacity="0.5" />
    </g>
  </svg>

  {/* ════════ MESOPELAGIC BAND ════════ */}

  {/* XLUUV — Boeing Orca (Extra Large UUV, ~50ft, sub-like silhouette) — oriented to drift LEFT (bow left) */}
  <svg
    class="bg-vessel bg-vessel-xluuv absolute"
    style="top: 76%; left: -10%; width: 540px; height: 72px;"
    viewBox="0 0 600 80"
    preserveAspectRatio="xMidYMid meet"
  >
    <g fill="var(--color-teal, #38e8c6)" opacity="0.22">
      {/* Long cylindrical hull — XLUUV scale (bow at left, stern at right) */}
      <path d="M 584 40 Q 580 12 550 10 L 60 10 Q 25 12 12 40 Q 25 68 60 70 L 550 70 Q 580 68 584 40 Z" />
      {/* Small access hatch / sensor mast (much smaller than manned-sub sail) */}
      <path d="M 400 10 Q 398 2 380 0 L 320 0 Q 302 2 298 10 Z" />
      {/* Comms / sensor mast */}
      <rect x="352" y="-4" width="2" height="6" />
      {/* Modular payload bay door (mid-hull — Orca carries payload modules) */}
      <rect x="120" y="40" width="160" height="2" opacity="0.50" />
