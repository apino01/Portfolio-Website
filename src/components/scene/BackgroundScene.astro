    {/* Seabed contact ellipse — full swath width */}
    <ellipse cx="600" cy="198" rx="596" ry="3.5" fill="var(--color-teal, #38e8c6)" opacity="0.20" />
  </svg>

  {/* ════════ ABYSSAL SEABED ════════ */}

  <svg
    class="bg-vessel bg-vessel-seabed absolute"
    style="bottom: 1%; left: 0; width: 100%; height: 110px;"
    viewBox="0 0 1200 130"
    preserveAspectRatio="none"
  >
    <g fill="var(--color-teal, #38e8c6)" opacity="0.16">
      <path d="M 0 100 Q 200 88 400 96 T 800 92 T 1200 100 L 1200 130 L 0 130 Z" />
