</div>

<style>
  :global(body) {
    position: relative;
  }

  .background-scene {
    contain: paint;
    /* Dim the entire scene so vessels read as ATMOSPHERE not foreground.
       Brightens slightly when user actively engages (no animation cost). */
    opacity: 0.55;
  }

  /* ─── Depth gradient (bottom darkness reduced from 0.72 → 0.65) ─── */
  .bg-depth-gradient {
    background: linear-gradient(
      to bottom,
      rgba(20, 45, 70, 0.20) 0%,
      rgba(12, 30, 52, 0.12) 16%,
      rgba(6, 18, 36, 0.06) 35%,
      rgba(2, 10, 22, 0.16) 60%,
      rgba(0, 4, 10, 0.46) 85%,
      rgba(0, 0, 0, 0.65) 100%
    );
  }

  /* ─── General vessel base ─── */
  .bg-vessel {
    will-change: transform;
    transform: translate3d(0, 0, 0);
  }

  /* ─── Drift animations ─── */
  .bg-vessel-ship       { animation: drift-right 110s linear infinite; }
  .bg-vessel-ohio       { animation: drift-right 180s linear infinite; }
  .bg-vessel-torpedo-lw { animation: drift-right 32s linear infinite; animation-delay: -8s; }
  .bg-vessel-virginia   { animation: drift-right 155s linear infinite; }
  .bg-vessel-torpedo-hw { animation: drift-right 38s linear infinite; animation-delay: -22s; }
  .bg-vessel-la         { animation: drift-left 150s linear infinite; }
  .bg-vessel-marlin     { animation: drift-left 130s linear infinite; }
  .bg-vessel-xluuv      { animation: drift-right 165s linear infinite; }
  .bg-vessel-mduuv      { animation: drift-right 140s linear infinite; }
  .bg-vessel-manta      { animation: drift-right 175s linear infinite; }
  /* Bottom-scanning UUV — drifts across the seabed while pinging (slow survey transit) */
  .bg-vessel-sonar-uuv  { animation: drift-right 95s linear infinite; }

  /* ─── Sonar ping animation (faster cadence) ─── */
  .bg-sonar-beam {
    animation: sonar-pulse 1.6s ease-in-out infinite;
    transform-box: fill-box;
    transform-origin: top center;
  }
  @keyframes sonar-pulse {
    0%, 100% { opacity: 0.6; }
    50%      { opacity: 1; }
  }

  /* Sonar return arcs — staggered expanding pings (bottom UUV) */
  .bg-sonar-arc {
    animation: sonar-arc 1.6s ease-out infinite;
  }
  .bg-sonar-arc-1 { animation-delay: 0s; }
  .bg-sonar-arc-2 { animation-delay: 0.2s; }
  .bg-sonar-arc-3 { animation-delay: 0.4s; }
  @keyframes sonar-arc {
    0%   { opacity: 0; }
    20%  { opacity: 0.55; }
    100% { opacity: 0; }
  }

  /* ─── Torpedo sonar — faster cadence (terminal-attack ping rate) ─── */
  .bg-torp-sonar {
    animation: torp-sonar-pulse 1.1s ease-in-out infinite;
  }
  @keyframes torp-sonar-pulse {
    0%, 100% { opacity: 0.55; }
    50%      { opacity: 1; }
  }

  .bg-torp-arc {
    animation: torp-arc 1.1s ease-out infinite;
  }
  .bg-torp-arc-1 { animation-delay: 0s; }
  .bg-torp-arc-2 { animation-delay: 0.18s; }
  .bg-torp-arc-3 { animation-delay: 0.36s; }
  @keyframes torp-arc {
    0%   { opacity: 0; }
    25%  { opacity: 0.65; }
    100% { opacity: 0; }
  }

  /* Torpedo sonar arcs — staggered expanding pings (forward from nose) */
  .bg-torp-arc {
    animation: torp-arc 2.2s ease-out infinite;
  }
  .bg-torp-arc-1 { animation-delay: 0s; }
  .bg-torp-arc-2 { animation-delay: 0.3s; }
  .bg-torp-arc-3 { animation-delay: 0.6s; }
  @keyframes torp-arc {
    0%   { opacity: 0; }
    25%  { opacity: 0.65; }
    100% { opacity: 0; }
  }

  @keyframes drift-right {
    0%   { transform: translate3d(0, 0, 0); }
    100% { transform: translate3d(130vw, 0, 0); }
  }
  @keyframes drift-left {
    0%   { transform: translate3d(0, 0, 0); }
    100% { transform: translate3d(-130vw, 0, 0); }
  }

  /* ═══════════════════════════════════════════════════════════════════════
     HELICOPTER + HELRAS DEPLOYMENT CHOREOGRAPHY (90s loop, 11 phases)
     ═══════════════════════════════════════════════════════════════════════ */

  /* Phase 1: helicopter container flies in/out horizontally */
  .bg-vessel-helo {
    animation: helo-flyby 90s cubic-bezier(0.45, 0, 0.55, 1) infinite;
  }
  @keyframes helo-flyby {
    0%   { transform: translate3d(220%, 0, 0); }   /* off-screen right */
    7%   { transform: translate3d(0, 0, 0); }       /* arrived */
    82%  { transform: translate3d(0, 0, 0); }       /* still on station */
    100% { transform: translate3d(-220%, 0, 0); }   /* off-screen left */
  }

  /* Phase 2: cable extends as sonar descends */
  .bg-helo-cable {
    transform-box: fill-box;
    transform-origin: top center;
    transform: scaleY(0);
    opacity: 0;
    animation: cable-extend 90s linear infinite;
  }
  @keyframes cable-extend {
    0%, 12%   { transform: scaleY(0); opacity: 0; }
    13%       { opacity: 1; }
    25%       { transform: scaleY(1); opacity: 1; }
    62%       { transform: scaleY(1); opacity: 1; }
    74%       { opacity: 1; }
    75%, 100% { transform: scaleY(0); opacity: 0; }
  }

  /* Phase 3: sonar rig descends along the cable */
  .bg-helo-sonar-rig {
    transform-box: fill-box;
    transform-origin: top center;
    transform: translateY(0);
    opacity: 0;
    animation: sonar-descent 90s linear infinite;
  }
  @keyframes sonar-descent {
    0%, 12%   { transform: translateY(0); opacity: 0; }
    13%       { opacity: 1; }
    25%       { transform: translateY(440px); opacity: 1; }
    62%       { transform: translateY(440px); opacity: 1; }
    74%       { opacity: 1; }
    75%, 100% { transform: translateY(0); opacity: 0; }
  }

  /* Phase 4: 8 arms deploy radially in lower hemisphere */
  .bg-helo-arm {
    transform-box: fill-box;
    transform-origin: left center;
    transform: rotate(var(--angle, 0deg)) scaleX(0);
    opacity: 0.50;
    animation: arm-deploy 90s linear infinite;
  }
  @keyframes arm-deploy {
    0%, 25%   { transform: rotate(var(--angle, 0deg)) scaleX(0); }
    32%       { transform: rotate(var(--angle, 0deg)) scaleX(1); }
    52%       { transform: rotate(var(--angle, 0deg)) scaleX(1); }
    62%, 100% { transform: rotate(var(--angle, 0deg)) scaleX(0); }
  }

  /* Phase 5: 3 hydrophone plates drop, hold, retract */
  .bg-helo-plate {
    transform-box: fill-box;
    transform-origin: top center;
    transform: translateY(0);
    opacity: 0;
    animation: plate-drop 90s linear infinite;
  }
  @keyframes plate-drop {
    0%, 32%   { transform: translateY(0); opacity: 0; }
    35%       { transform: translateY(0); opacity: 0.75; }
    42%, 46%  { transform: translateY(18px); opacity: 0.75; }
    49%       { transform: translateY(0); opacity: 0.75; }
    52%, 100% { transform: translateY(0); opacity: 0; }
  }

  /* ─── Caustics shimmer ─── */
  .bg-caustics {
    animation: caustics-shimmer 14s ease-in-out infinite;
    transform-origin: 50% 0%;
  }
  @keyframes caustics-shimmer {
    0%, 100% { transform: scaleY(1);    opacity: 0.05; }
    50%      { transform: scaleY(1.08); opacity: 0.08; }
  }

  /* ─── Reduced motion: freeze in mid-deployment, no drift ─── */
  @media (prefers-reduced-motion: reduce) {
    .bg-vessel,
    .bg-caustics,
    .bg-helo-cable,
    .bg-helo-sonar-rig,
    .bg-helo-arm,
    .bg-helo-plate {
      animation: none;
    }
    .bg-vessel-ship       { transform: translate3d(45vw, 0, 0); }
    .bg-vessel-ohio       { transform: translate3d(45vw, 0, 0); }
    .bg-vessel-torpedo-lw { transform: translate3d(60vw, 0, 0); }
    .bg-vessel-virginia   { transform: translate3d(40vw, 0, 0); }
    .bg-vessel-torpedo-hw { transform: translate3d(50vw, 0, 0); }
    .bg-vessel-la         { transform: translate3d(-50vw, 0, 0); }
    .bg-vessel-marlin     { transform: translate3d(-45vw, 0, 0); }
    .bg-vessel-xluuv      { transform: translate3d(40vw, 0, 0); }
    .bg-vessel-mduuv      { transform: translate3d(40vw, 0, 0); }
    .bg-vessel-manta      { transform: translate3d(35vw, 0, 0); }
    .bg-vessel-sonar-uuv  { transform: translate3d(40vw, 0, 0); }
    /* Pings frozen mid-cycle for visual interest */
    .bg-sonar-beam        { opacity: 0.85; animation: none; }
    .bg-sonar-arc         { opacity: 0.45; animation: none; }
    .bg-torp-sonar        { opacity: 0.85; animation: none; }
    .bg-torp-arc          { opacity: 0.55; animation: none; }
    /* Helicopter parked on-station with sonar fully deployed for visual interest */
    .bg-vessel-helo       { transform: translate3d(0, 0, 0); }
    .bg-helo-cable        { transform: scaleY(1); opacity: 1; }
    .bg-helo-sonar-rig    { transform: translateY(440px); opacity: 1; }
    .bg-helo-arm          { transform: rotate(var(--angle, 0deg)) scaleX(1); }
    .bg-helo-plate        { transform: translateY(0); opacity: 0; }
  }
</style>
