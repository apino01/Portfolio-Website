---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<header class="mb-8 flex items-baseline gap-4">
  <h2 class="text-2xl font-semibold text-near-white sm:text-3xl">
    {title}
  </h2>
  <span
    class="ml-2 hidden h-px flex-1 translate-y-[-0.4em] bg-slate/20 sm:block"
    aria-hidden="true"></span>
</header>
