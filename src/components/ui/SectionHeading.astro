---
interface Props {
  title: string;
  /** Optional 2-digit ordinal prefix shown as small mono eyebrow above title. */
  number?: string;
}
const { title, number } = Astro.props;
---

<header
  class="section-heading mb-10"
  data-section-heading
>
  {
    number && (
      <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-teal/85">
        Section {number}
      </p>
    )
  }
  <div class="mt-2 flex items-center gap-4">
    <h2 class="text-2xl font-semibold tracking-tight text-near-white sm:text-3xl">
      {title}
    </h2>
    <span
      class="ml-1 hidden h-px flex-1 translate-y-[1px] bg-gradient-to-r from-slate/30 to-transparent sm:block"
      aria-hidden="true"></span>
  </div>
</header>

<style>
  .section-heading {
    opacity: 0;
    transition: opacity 600ms ease-out;
  }
  .section-heading.is-visible {
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .section-heading {
      opacity: 1;
      transition: none;
    }
  }
</style>

<script>
  const headings = document.querySelectorAll<HTMLElement>("[data-section-heading]");
  if ("IntersectionObserver" in window && headings.length > 0) {
    const obs = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add("is-visible");
            obs.unobserve(e.target);
          }
        }
      },
      { threshold: 0.15, rootMargin: "0px 0px -10% 0px" }
    );
    headings.forEach((h) => obs.observe(h));
  } else {
    headings.forEach((h) => h.classList.add("is-visible"));
  }
</script>
