---
import SectionHeading from "~/components/ui/SectionHeading.astro";
import IconLink from "~/components/ui/IconLink.astro";
import LinkedInIcon from "~/components/ui/icons/LinkedInIcon.astro";
import MailIcon from "~/components/ui/icons/MailIcon.astro";

// Formspree endpoint — replace YOUR_ID once the form is provisioned at formspree.io.
const formspreeEndpoint = "https://formspree.io/f/xjgjzrjz";
const directEmail = "andres.m.pino@gmail.com";
---

<section
  id="contact"
  aria-labelledby="contact-heading"
  class="scroll-mt-24"
>
  <SectionHeading title="Contact" />

  <div class="grid gap-10 lg:grid-cols-[minmax(0,3fr)_minmax(0,2fr)]">
    <div>
      <p class="max-w-prose text-slate">
        Open to advisory, fractional, and consulting engagements — power
        electronics, directed energy, undersea autonomy, and systems
        engineering leadership. Send a short note about your problem and a
        timeline; I reply within two business days.
      </p>

      <form
        action={formspreeEndpoint}
        method="POST"
        class="mt-8 grid gap-5"
        data-contact-form
      >
        <div class="grid gap-2">
          <label
            for="contact-name"
            class="font-mono text-xs uppercase tracking-widest text-slate/80"
          >
            Name
          </label>
          <input
            id="contact-name"
            name="name"
            type="text"
            required
            autocomplete="name"
            class="rounded-md border border-slate/20 bg-deep-navy/40 px-4 py-3 text-near-white placeholder:text-slate/50 focus:border-teal focus:outline-none focus:ring-1 focus:ring-teal"
          />
        </div>

        <div class="grid gap-2">
          <label
            for="contact-email"
            class="font-mono text-xs uppercase tracking-widest text-slate/80"
          >
            Email
          </label>
          <input
            id="contact-email"
            name="email"
            type="email"
            required
            autocomplete="email"
            class="rounded-md border border-slate/20 bg-deep-navy/40 px-4 py-3 text-near-white placeholder:text-slate/50 focus:border-teal focus:outline-none focus:ring-1 focus:ring-teal"
          />
        </div>

        <div class="grid gap-2">
          <label
            for="contact-organization"
            class="font-mono text-xs uppercase tracking-widest text-slate/80"
          >
            Organization <span class="text-slate/50">(optional)</span>
          </label>
          <input
            id="contact-organization"
            name="organization"
            type="text"
            autocomplete="organization"
            class="rounded-md border border-slate/20 bg-deep-navy/40 px-4 py-3 text-near-white placeholder:text-slate/50 focus:border-teal focus:outline-none focus:ring-1 focus:ring-teal"
          />
        </div>

        <div class="grid gap-2">
          <label
            for="contact-message"
            class="font-mono text-xs uppercase tracking-widest text-slate/80"
          >
            Message
          </label>
          <textarea
            id="contact-message"
            name="message"
            rows="5"
            required
            class="resize-y rounded-md border border-slate/20 bg-deep-navy/40 px-4 py-3 text-near-white placeholder:text-slate/50 focus:border-teal focus:outline-none focus:ring-1 focus:ring-teal"
          ></textarea>
        </div>

        {/* Honeypot — hidden field bots fill in. */}
        <input
          type="text"
          name="_gotcha"
          tabindex="-1"
          autocomplete="off"
          class="hidden"
          aria-hidden="true"
        />

        <div class="flex items-center gap-4">
          <button
            type="submit"
            class="inline-flex items-center gap-2 rounded-md border border-teal/40 bg-teal/10 px-5 py-3 font-mono text-sm text-teal transition-colors hover:bg-teal/20 focus:outline-none focus:ring-2 focus:ring-teal disabled:opacity-60"
          >
            Send message
            <span aria-hidden="true">→</span>
          </button>
          <p
            data-form-status
            role="status"
            aria-live="polite"
            class="font-mono text-xs text-slate"
          ></p>
        </div>
      </form>
    </div>

    <aside class="grid content-start gap-6">
      <div>
        <p class="font-mono text-xs uppercase tracking-widest text-slate/80">
          Direct
        </p>
        <a
          href={`mailto:${directEmail}`}
          class="mt-2 inline-block break-all text-near-white hover:text-teal"
        >
          {directEmail}
        </a>
      </div>

      <div>
        <p class="font-mono text-xs uppercase tracking-widest text-slate/80">
          Elsewhere
        </p>
        <div class="mt-2 flex gap-2">
          <IconLink
            href="https://www.linkedin.com/in/andresmpino/"
            label="LinkedIn"
          >
            <LinkedInIcon />
          </IconLink>
          <IconLink href={`mailto:${directEmail}`} label="Email">
            <MailIcon />
          </IconLink>
        </div>
      </div>

      <div>
        <p class="font-mono text-xs uppercase tracking-widest text-slate/80">
          Location
        </p>
        <p class="mt-2 text-slate">San Diego, CA</p>
      </div>
    </aside>
  </div>
</section>

<script>
  const form = document.querySelector<HTMLFormElement>("[data-contact-form]");
  const status = document.querySelector<HTMLElement>("[data-form-status]");

  if (form && status) {
    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      const data = new FormData(form);
      const button = form.querySelector<HTMLButtonElement>("button[type=submit]");
      if (button) button.disabled = true;
      status.textContent = "Sending…";
      status.classList.remove("text-teal", "text-red-400");

      try {
        const response = await fetch(form.action, {
          method: "POST",
          body: data,
          headers: { Accept: "application/json" },
        });
        if (response.ok) {
          form.reset();
          status.textContent = "Message sent. I'll reply within two business days.";
          status.classList.add("text-teal");
        } else {
          const payload = await response.json().catch(() => null);
          const detail = payload?.errors?.[0]?.message ?? "Send failed. Email me directly.";
          status.textContent = detail;
          status.classList.add("text-red-400");
        }
      } catch {
        status.textContent = "Network error. Email me directly.";
        status.classList.add("text-red-400");
      } finally {
        if (button) button.disabled = false;
      }
    });
  }
</script>
